# PostgreSQL Database connection string (Required for persistent storage)
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
# Note: Coolify provides this URL in their database dashboard
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kpbabu

# Port number for Express API server to bind to (Default: 5000)
PORT=5000

# Environment mode (development or production)
NODE_ENV=development
